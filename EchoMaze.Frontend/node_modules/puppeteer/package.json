  },
  "type": "module",
  "types": "./lib/types.d.ts",
  "version": "25.1.0",
  "wireit": {
    "prepack": {
      "command": "node --experimental-strip-types ../../tools/cp.ts ../../README.md README.md",
      "files": [
        "../../README.md"
      ],
      "output": [
        "README.md"
      ]
    },
    "build": {
      "dependencies": [
        "build:tsc",
        "build:types"
      ]
    },
    "build:docs": {
      "command": "api-extractor run --local --config \"./api-extractor.docs.json\"",
      "files": [
        "api-extractor.docs.json",
        "lib/puppeteer/puppeteer.docs.d.ts",
        "tsconfig.json"
      ],
      "dependencies": [
        "build:tsc"
      ]
    },
    "build:tsc": {
      "command": "tsc -b && node --experimental-strip-types ../../tools/chmod.ts 755 lib/puppeteer/node/cli.js",
      "clean": "if-file-deleted",
      "dependencies": [
        "../puppeteer-core:build",
        "../browsers:build"
      ],
      "files": [
        "src/**"
      ],
      "output": [
        "lib/**",
        "!lib/package.json"
      ]
    },
    "build:types": {
      "command": "api-extractor run --local && eslint --fix lib/types.d.ts --no-ignore",
      "files": [
        "api-extractor.json",
        "lib/puppeteer/types.d.ts",
        "tsconfig.json"
      ],
      "output": [
        "lib/types.d.ts"
      ],
      "dependencies": [
        "build:tsc"
      ]
    }
  }
